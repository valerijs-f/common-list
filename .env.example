# Jazz sync server URL
# Example: wss://cloud.jazz.tools/?key=your-key-or-token
VITE_JAZZ_PEER_URL=
VITE_SHOW_JAZZ_INSPECTOR=true
# Optional. Set to your production hostname so WebAuthn relying party ID matches the deployed site.
# Leave unset for localhost development.
# VITE_JAZZ_PASSKEY_HOSTNAME=
